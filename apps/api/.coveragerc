[run]
omit =
    # Pure string constants — no testable logic
    app/domains/prompts/templates.py
    # DB session setup
    app/db/session.py
    # App entrypoint
    app/main.py
    # Integration-only: makes real LLM API calls, not unit-testable
    app/domains/simulation/runner.py
    # Integration-only: requires real SMTP connection
    app/observability/email.py

[report]
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    raise NotImplementedError
