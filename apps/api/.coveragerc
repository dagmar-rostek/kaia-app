[run]
omit =
    # Pure string constants — no testable logic
    app/domains/prompts/templates.py
    # DB session setup
    app/db/session.py
    # App entrypoint
    app/main.py
    # Integration-only: makes real LLM API calls, not unit-testable
    app/domains/simulation/runner.py
    # Integration-only: LLM-Judge scoring, requires real API keys
    app/domains/eval/evaluator.py
    # Pure data constants — persona prompt strings, no logic
    app/domains/simulation/eval_personas.py
    # Integration-only: LLM session summarisation, requires real API keys
    app/domains/chat/summary.py
    # Integration-only: requires real SMTP connection
    app/observability/email.py

[report]
exclude_lines =
    pragma: no cover
    if TYPE_CHECKING:
    raise NotImplementedError
